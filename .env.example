# Chave da API Anthropic (para análise qualitativa com IA)
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Configurações do município alvo
MUNICIPIO_NOME=Sorocaba
MUNICIPIO_IBGE_CODE=3552205   # Código IBGE de Sorocaba

# URL base do portal de transparência (ajustar conforme o portal local)
PORTAL_SOROCABA_BASE_URL=https://transparencia.sorocaba.sp.gov.br

# API BPS do Ministério da Saúde
BPS_API_BASE_URL=https://apibps.saude.gov.br/api

# Brasil API (CNPJ da Receita Federal)
BRASIL_API_BASE_URL=https://brasilapi.com.br/api/cnpj/v1

# Threshold de alerta (percentual acima do BPS para gerar alerta)
THRESHOLD_ATENCAO=30
THRESHOLD_ALERTA=60
THRESHOLD_CRITICO=100

# Diretório de saída
OUTPUT_DIR=data/reports
